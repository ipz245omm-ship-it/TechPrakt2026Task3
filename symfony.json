{
  "info": {
    "name": "Symfony CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET answers",
      "request": {
        "method": "GET",
        "url": "http://127.0.0.1:8000/api/answers"
      }
    },
    {
      "name": "POST answer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"answer\": \"Hello Symfony\" }"
        },
        "url": "http://127.0.0.1:8000/api/answers"
      }
    },
    {
      "name": "PATCH answer",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"answer\": \"Updated Symfony\" }"
        },
        "url": "http://127.0.0.1:8000/api/answers/1"
      }
    },
    {
      "name": "DELETE answer",
      "request": {
        "method": "DELETE",
        "url": "http://127.0.0.1:8000/api/answers/1"
      }
    }
  ]
}